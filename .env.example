# =============================================================================
# OANDA — switch practice vs live with a SINGLE variable.
# Get a free practice account: https://www.oanda.com/demo-account/
# API tokens: https://www.oanda.com/demo-account/tpa/personal_token
# =============================================================================
OANDA_ENV=practice                           # practice | live
OANDA_ACCOUNT_ID=000-000-00000000-000
OANDA_API_TOKEN=replace-me

# =============================================================================
# Database — TimescaleDB (Postgres extension) for OHLCV + trades + snapshots
# =============================================================================
POSTGRES_HOST=localhost
POSTGRES_PORT=5433                           # mapped to container 5432 to avoid clash with local pg
POSTGRES_DB=tbot
POSTGRES_USER=tbot
POSTGRES_PASSWORD=tbot

# =============================================================================
# Redis — position cache, rate limit state, heartbeats
# =============================================================================
REDIS_URL=redis://localhost:6380/0

# =============================================================================
# Risk defaults — these are HARD limits enforced before any order leaves the OMS.
# Override per-strategy via strategy params. Tune these conservatively at first.
# =============================================================================
MAX_ACCOUNT_RISK_PCT=0.005                   # max 0.5% account loss per trade
MAX_DAILY_LOSS_PCT=0.02                      # kill switch at 2% daily drawdown
MAX_OPEN_POSITIONS=5
MAX_LEVERAGE=5                               # cap leverage well below broker default

# =============================================================================
# Alerts (optional during dev — leave blank to disable)
# =============================================================================
SLACK_WEBHOOK_URL=

# =============================================================================
# Operational
# =============================================================================
LOG_LEVEL=INFO                               # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                              # json | console
HEARTBEAT_SECONDS=30                         # how often the bot pings its health key in Redis
